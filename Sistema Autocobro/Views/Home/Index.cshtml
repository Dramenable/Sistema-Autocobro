@{
    ViewData["Title"] = "Autocobro";
}

<section class="mb-4">
    <div class="p-4 p-lg-5 rounded-4 text-white checkout-hero">
        <div class="row align-items-center g-4">
            <div class="col-lg-8">
                <span class="badge bg-light text-primary fw-semibold mb-3">Kiosco inteligente</span>
                <h1 class="display-5 fw-bold mb-3">Sistema de autocobro para tienda</h1>
                <p class="lead mb-0">Escanea productos, aplica promociones y completa el pago sin filas con una experiencia rápida, clara y segura.</p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <div class="checkout-kpi d-inline-block text-start">
                    <p class="mb-1 small text-uppercase opacity-75">Tiempo promedio de compra</p>
                    <p class="h2 fw-bold mb-2">2:35 min</p>
                    <p class="mb-0 small">Última sincronización: 10:24 AM</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="row g-4">
    <div class="col-xl-8">
        <div class="card shadow-sm border-0 rounded-4 h-100">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-md-row gap-3 justify-content-between align-items-md-center mb-4">
                    <div>
                        <h2 class="h4 mb-1">Escaneo de productos</h2>
                        <p class="text-muted mb-0">Ingresa código de barras o selecciona un producto sugerido.</p>
                    </div>
                    <div class="input-group quick-scan">
                        <span class="input-group-text bg-white">#</span>
                        <input type="text" class="form-control" placeholder="Ej. 7501031311309" aria-label="Codigo de barras" />
                        <button class="btn btn-primary" type="button">Agregar</button>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Cant.</th>
                                <th class="text-end">Precio</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>
                                    <p class="fw-semibold mb-0">Leche Entera 1L</p>
                                    <small class="text-muted">SKU: LACT-1001</small>
                                </td>
                                <td class="text-center">1</td>
                                <td class="text-end">$28.00</td>
                                <td class="text-end fw-semibold">$28.00</td>
                            </tr>
                            <tr>
                                <td>
                                    <p class="fw-semibold mb-0">Pan Integral</p>
                                    <small class="text-muted">SKU: BAK-2240</small>
                                </td>
                                <td class="text-center">2</td>
                                <td class="text-end">$39.00</td>
                                <td class="text-end fw-semibold">$78.00</td>
                            </tr>
                            <tr>
                                <td>
                                    <p class="fw-semibold mb-0">Café Molido 500g</p>
                                    <small class="text-muted">SKU: CAFE-5700</small>
                                </td>
                                <td class="text-center">1</td>
                                <td class="text-end">$129.00</td>
                                <td class="text-end fw-semibold">$129.00</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-3">
                    <button class="btn btn-outline-primary">Añadir bolsa ecológica</button>
                    <button class="btn btn-outline-secondary">Aplicar cupón</button>
                    <button class="btn btn-outline-danger">Vaciar carrito</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body p-4">
                <h2 class="h5 mb-3">Resumen de compra</h2>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Subtotal</span>
                    <span>$235.00</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Descuento Club</span>
                    <span class="text-success">-$15.00</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">IVA</span>
                    <span>$35.20</span>
                </div>
                <hr />
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <span class="h6 mb-0">Total a pagar</span>
                    <span class="h4 mb-0 fw-bold">$255.20</span>
                </div>

                <div class="d-grid gap-2">
                    <button class="btn btn-success btn-lg">Pagar ahora</button>
                    <button class="btn btn-outline-dark">Generar ticket digital</button>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4">
                <h2 class="h6 text-uppercase text-muted mb-3">Métodos de pago</h2>
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <span class="badge text-bg-light">Tarjeta crédito/débito</span>
                    <span class="badge text-bg-light">NFC / Wallet</span>
                    <span class="badge text-bg-light">Código QR</span>
                    <span class="badge text-bg-light">Vales</span>
                </div>
                <p class="small text-muted mb-0">Este kiosco cumple con PCI-DSS y cifra la información de pago de extremo a extremo.</p>
            </div>
        </div>
    </div>
</section>
